-- ==================================================================
-- 8. Query Planning and Execution
-- ==================================================================
-- Simple scan should execute only on coordinator
EXPLAIN SELECT * FROM coordinator_only_heap;
                                QUERY PLAN                                
--------------------------------------------------------------------------
 Seq Scan on coordinator_only_heap  (cost=0.00..81.10 rows=7110 width=18)
 Optimizer: Postgres-based planner
(2 rows)

-- Join with distributed table (should broadcast coordinator-only table)
EXPLAIN SELECT * FROM coordinator_only_heap c, distributed_table_aux d
WHERE c.c1 = d.c2;
                                             QUERY PLAN                                             
----------------------------------------------------------------------------------------------------
 Gather Motion 3:1  (slice1; segments: 3)  (cost=205.53..2610.87 rows=86100 width=26)
   ->  Hash Join  (cost=205.53..1462.87 rows=28700 width=26)
         Hash Cond: (d.c2 = c.c1)
         ->  Redistribute Motion 3:3  (slice2; segments: 3)  (cost=0.00..895.00 rows=28700 width=8)
               Hash Key: d.c2
               ->  Seq Scan on distributed_table_aux d  (cost=0.00..321.00 rows=28700 width=8)
         ->  Hash  (cost=175.90..175.90 rows=2370 width=18)
               ->  Redistribute Motion 1:3  (slice3)  (cost=0.00..175.90 rows=2370 width=18)
                     Hash Key: c.c1
                     ->  Seq Scan on coordinator_only_heap c  (cost=0.00..81.10 rows=7110 width=18)
 Optimizer: Postgres-based planner
(11 rows)

-- Aggregation on coordinator-only table
EXPLAIN SELECT COUNT(*), AVG(c1), MAX(c3) FROM coordinator_only_heap;
                                   QUERY PLAN                                   
--------------------------------------------------------------------------------
 Aggregate  (cost=134.43..134.44 rows=1 width=72)
   ->  Seq Scan on coordinator_only_heap  (cost=0.00..81.10 rows=7110 width=10)
 Optimizer: Postgres-based planner
(3 rows)

SELECT COUNT(*), AVG(c1)::NUMERIC(10,2), MAX(c3) FROM coordinator_only_heap;
 count |  avg   |  max   
-------+--------+--------
   800 | 400.50 | 600.00
(1 row)

-- Subquery
EXPLAIN SELECT * FROM distributed_table_aux
WHERE c2 IN (SELECT c1 FROM coordinator_only_heap WHERE c1 < 500);
                                           QUERY PLAN                                            
-------------------------------------------------------------------------------------------------
 Gather Motion 3:1  (slice1; segments: 3)  (cost=318.36..1190.58 rows=27261 width=8)
   ->  Hash Join  (cost=318.36..827.10 rows=9087 width=8)
         Hash Cond: (distributed_table_aux.c2 = coordinator_only_heap.c1)
         ->  Seq Scan on distributed_table_aux  (cost=0.00..392.75 rows=9567 width=8)
               Filter: (c2 < 500)
         ->  Hash  (cost=233.94..233.94 rows=6753 width=4)
               ->  Broadcast Motion 1:3  (slice2)  (cost=0.00..233.94 rows=6753 width=4)
                     ->  Seq Scan on coordinator_only_heap  (cost=0.00..98.88 rows=6753 width=4)
                           Filter: (c1 < 500)
 Optimizer: Postgres-based planner
(10 rows)

