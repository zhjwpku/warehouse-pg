------------+-------------+---------+-----------
 e          |          -1 |         | 
(1 row)

CREATE TABLE coordinator_only_aoco (c1 BIGINT, c2 FLOAT, c3 DATE)
    USING ao_column
    DISTRIBUTED COORDINATOR ONLY;
