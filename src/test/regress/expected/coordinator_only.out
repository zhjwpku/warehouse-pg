 c2     | character varying(50) |           |          |         | extended |              | 
Distributed by: DISTRIBUTED COORDINATOR ONLY
Options: blocksize=32768, compresslevel=0, compresstype=none, checksum=true

SELECT policytype, numsegments, distkey, distclass
FROM gp_distribution_policy
WHERE localoid = 'coordinator_only_ao'::regclass;
